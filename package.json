{
  "name": "petrparker",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "stage:offline-bundle": "node scripts/stage-offline-bundle.ts",
    "app:refresh-offline-bundle": "npm run export:sqlite-bundle && npm run stage:offline-bundle",
    "lint": "expo lint",
    "ingest:park-listing": "node services/ingestion/sources/fetch-park-listing.ts",
    "ingest:open-data": "node services/ingestion/sources/fetch-open-data.ts",
    "ingest:park-pages": "node services/ingestion/sources/fetch-park-pages.ts",
    "parse:park-pages": "node services/ingestion/transform/parse-park-page.ts",
    "build:canonical-parks": "node services/ingestion/transform/build-canonical-park.ts",
    "qa:validate-catalog": "node services/ingestion/qa/validate-catalog.ts",
    "export:sqlite-bundle": "node services/ingestion/export/build-sqlite-bundle.ts",
    "publish:offline-bundle": "node services/ingestion/export/publish-offline-bundle.ts",
    "sync:ingestion-to-s3": "node services/ingestion/export/sync-to-s3.ts",
    "ingest:bootstrap": "npm run ingest:park-listing && npm run ingest:open-data"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
